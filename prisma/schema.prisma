generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String        @unique
  password      String?
  image         String?
  ragContext    String?       @db.Text
  dailyGoal     Int           @default(1000)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  sessions      ChatSession[]
  books         Book[]
  documents     Document[]
  dailyProgress DailyProgress[]
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  title     String        @default("Nova Conversa")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  @@index([userId])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      String      // "user" or "assistant"
  content   String
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Book {
  id          String     @id @default(cuid())
  userId      String
  title       String     @default("Sem Título")
  coverImage  String?    @db.Text
  targetWords Int        @default(50000)
  defaultFontSize String? @default("18px")
  defaultFontFamily String? @default("Inter")
  defaultFontWeight String? @default("400")
  defaultParagraphIndent Boolean? @default(false)
  securityType String?    @default("none") // "none", "pin", "biometrics"
  pin          String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents   Document[]
  characters  Character[]
  notes       BookNote[]

  @@index([userId])
}

model Document {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("Sem Título")
  order     Int      @default(0)
  content    String?  @db.Text
  wordCount  Int      @default(0)
  wordGoal   Int      @default(5000)
  customGoal String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt DateTime @updatedAt
  bookId    String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book?    @relation(fields: [bookId], references: [id], onDelete: Cascade)
  themeBgColor      String?  @default("#0B0F12")
  themeBgImage      String?  @db.Text
  themeFontColor    String?  @default("rgba(255,255,255,0.93)")
  themeToolbarColor String?  @default("rgba(255,255,255,0.04)")

  @@index([userId])
  @@index([bookId])
}

model Character {
  id          String   @id @default(cuid())
  bookId      String
  name        String
  role        String?  // Protagonist, Antagonist, etc
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  book        Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
}

model BookNote {
  id          String   @id @default(cuid())
  bookId      String
  title       String
  content     String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  book        Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
}

model DailyProgress {
  id        String   @id @default(cuid())
  userId    String
  date      String   // Formato YYYY-MM-DD
  words     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}
